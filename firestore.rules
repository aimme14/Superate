rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // CAPA 1: Custom claims (zero lecturas Firestore)
    // Disponibles cuando claimsRev está presente en el token (set por setUserClaims).
    // ─────────────────────────────────────────────────────────────────────────

    function hasClaimsRev() {
      return request.auth != null && request.auth.token.claimsRev != null;
    }

    function tokenIsAdmin() {
      return hasClaimsRev() &&
        request.auth.token.role == 'admin' &&
        request.auth.token.active == true;
    }

    function tokenCanAccess() {
      return hasClaimsRev() &&
        request.auth.token.active == true &&
        (
          request.auth.token.role == 'admin' ||
          (
            request.auth.token.institutionActive == true &&
            (
              request.auth.token.role == 'student' ||
              request.auth.token.role == 'teacher' ||
              request.auth.token.role == 'rector'
            )
          )
        );
    }

    function tokenSameInstitution(institutionId) {
      return hasClaimsRev() &&
        request.auth.token.active == true &&
        request.auth.token.institutionActive == true &&
        request.auth.token.institutionId == institutionId &&
        (
          request.auth.token.role == 'student' ||
          request.auth.token.role == 'teacher' ||
          request.auth.token.role == 'rector'
        );
    }

    // ─────────────────────────────────────────────────────────────────────────
    // CAPA 2: Fallback Firestore (solo cuando claims no disponibles)
    // Cada función hace el mínimo de lecturas posible.
    // ─────────────────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin: única lectura en users/ (solo admins viven ahí).
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/superate/auth/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/superate/auth/users/$(request.auth.uid)).data.isActive == true &&
        get(/databases/$(database)/documents/superate/auth/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Verifica que el uid tenga un userLookup válido y su doc de rol esté activo.
    // Máximo 2 lecturas: userLookup + doc de rol.
    function isActiveNonAdmin() {
      let lookup = get(/databases/$(database)/documents/superate/auth/userLookup/$(request.auth.uid)).data;
      let instId = lookup.institutionId;
      let role = lookup.role;
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/superate/auth/userLookup/$(request.auth.uid)) &&
        (
          (role == 'rector' &&
            exists(/databases/$(database)/documents/superate/auth/institutions/$(instId)/rectores/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/superate/auth/institutions/$(instId)/rectores/$(request.auth.uid)).data.isActive == true) ||
          (role == 'teacher' &&
            exists(/databases/$(database)/documents/superate/auth/institutions/$(instId)/profesores/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/superate/auth/institutions/$(instId)/profesores/$(request.auth.uid)).data.isActive == true) ||
          (role == 'student' &&
            exists(/databases/$(database)/documents/superate/auth/institutions/$(instId)/estudiantes/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/superate/auth/institutions/$(instId)/estudiantes/$(request.auth.uid)).data.isActive == true)
        );
    }

    // Institución activa: 1 lectura.
    function isInstitutionActive(institutionId) {
      return exists(/databases/$(database)/documents/superate/auth/institutions/$(institutionId)) &&
        get(/databases/$(database)/documents/superate/auth/institutions/$(institutionId)).data.isActive == true;
    }

    // Usuario activo en institución específica: userLookup + isInstitutionActive + doc rol = 3 lecturas máximo.
    function isMemberOfInstitution(institutionId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/superate/auth/userLookup/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/superate/auth/userLookup/$(request.auth.uid)).data.institutionId == institutionId &&
        isInstitutionActive(institutionId) &&
        isActiveNonAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // CAPA 3: Combinadas (claims primero, fallback después)
    // ─────────────────────────────────────────────────────────────────────────

    // Admin por claims o Firestore.
    function isAdminOrToken() {
      return tokenIsAdmin() || isAdmin();
    }

    // Acceso general: usuario activo con institución activa.
    function canAccess() {
      return tokenCanAccess() || isAdmin() || isActiveNonAdmin();
    }

    // Miembro activo de una institución específica.
    function sameInstitution(institutionId) {
      return tokenSameInstitution(institutionId) || isMemberOfInstitution(institutionId);
    }

    // Acceso a recursos de una institución: miembro o admin.
    function canAccessInstitution(institutionId) {
      return sameInstitution(institutionId) || isAdminOrToken();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // REGLAS DE COLECCIONES
    // ─────────────────────────────────────────────────────────────────────────

    // Admin en estructura legacy (solo admins).
    match /superate/auth/users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAdminOrToken() ||
        (resource != null && resource.data.role == 'admin' && resource.data.email == request.auth.token.email)
      );
      allow create, update, delete: if isAdminOrToken();
    }

    // Índice uid → institutionId + rol.
    match /superate/auth/userLookup/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdminOrToken());
      allow create, update, delete: if isAdminOrToken();
    }

    // Instituciones.
    match /superate/auth/institutions/{institutionId} {
      allow read: if canAccessInstitution(institutionId);
      allow create: if isAdminOrToken() && request.resource.data.isActive != null;
      allow update: if isAdminOrToken() &&
        (request.resource.data.isActive == true || request.resource.data.isActive == false);
      allow delete: if isAdminOrToken();
    }

    // Rectores.
    match /superate/auth/institutions/{institutionId}/rectores/{rectorId} {
      allow read: if isAuthenticated() && request.auth.uid == rectorId;
      allow read: if canAccessInstitution(institutionId);
      allow update: if canAccessInstitution(institutionId) &&
        request.auth.uid == rectorId &&
        request.resource.data.role == 'rector' &&
        request.resource.data.isActive == resource.data.isActive;
      allow create: if isAdminOrToken() &&
        request.resource.data.isActive != null &&
        request.resource.data.role == 'rector';
      allow update: if isAdminOrToken() &&
        request.resource.data.role == 'rector';
      allow delete: if isAdminOrToken();
    }

    // Coordinadores — rol legacy, solo lectura admin. No se crean nuevos.
    match /superate/auth/institutions/{institutionId}/coordinadores/{coordinadorId} {
      allow read: if isAuthenticated() && request.auth.uid == coordinadorId;
      allow read: if isAdminOrToken();
      allow create, update, delete: if isAdminOrToken();
    }

    // Profesores.
    match /superate/auth/institutions/{institutionId}/profesores/{profesorId} {
      allow read: if isAuthenticated() && request.auth.uid == profesorId;
      allow read: if canAccessInstitution(institutionId);
      allow update: if canAccessInstitution(institutionId) &&
        request.auth.uid == profesorId &&
        request.resource.data.role == 'teacher' &&
        request.resource.data.isActive == resource.data.isActive;
      allow create: if isAdminOrToken() &&
        request.resource.data.isActive != null &&
        request.resource.data.role == 'teacher';
      allow update: if isAdminOrToken() &&
        request.resource.data.role == 'teacher';
      allow delete: if isAdminOrToken();
    }

    // Estudiantes.
    match /superate/auth/institutions/{institutionId}/estudiantes/{estudianteId} {
      allow read: if isAuthenticated() && request.auth.uid == estudianteId;
      allow read: if canAccessInstitution(institutionId);
      allow update: if canAccessInstitution(institutionId) &&
        request.auth.uid == estudianteId &&
        request.resource.data.role == 'student' &&
        request.resource.data.isActive == resource.data.isActive;
      allow create: if isAdminOrToken() &&
        request.resource.data.isActive != null &&
        request.resource.data.role == 'student';
      allow update: if isAdminOrToken() &&
        request.resource.data.role == 'student';
      allow delete: if isAdminOrToken();
    }

    // Snapshots analíticos por institución.
    match /superate/auth/institutions/{institutionId}/analyticsSnapshots/{snapshotId} {
      allow read, write: if canAccessInstitution(institutionId);
    }

    // Resumen de progreso por estudiante — solo Cloud Functions escribe.
    match /superate/auth/institutions/{institutionId}/studentSummaries/{studentId} {
      allow read: if canAccessInstitution(institutionId);
      allow write: if false;
    }

    // Resumen por grado — solo Cloud Functions escribe.
    match /superate/auth/institutions/{institutionId}/gradeSummary/{gradeSummaryId} {
      allow read: if canAccessInstitution(institutionId);
      allow write: if false;
    }

    // Resumen institucional — solo Cloud Functions escribe.
    match /superate/auth/institutions/{institutionId}/institutionSummary/{summaryId} {
      allow read: if canAccessInstitution(institutionId);
      allow write: if false;
    }

    // Cola de sincronización de claims — solo Cloud Functions escribe.
    match /superate/auth/_syncClaimsQueue/{uid} {
      allow read, write: if false;
    }

    // Preguntas del banco.
    match /superate/auth/questions/{questionId} {
      allow read: if canAccess();
      allow create: if canAccess() && isAdminOrToken();
      allow update: if canAccess() &&
        (isAdminOrToken() || resource.data.createdBy == request.auth.uid);
      allow delete: if isAdminOrToken();
    }

    // Contadores.
    match /superate/auth/counters/{counterId} {
      allow read, write: if isAdminOrToken();
    }

    // Configuración: registro de usuarios (lectura pública).
    match /superate/auth/system/registration {
      allow read: if true;
      allow write: if isAdminOrToken();
    }

    // Configuración: autorización global de fases.
    match /superate/auth/system/Autorizacion_fases {
      allow read: if isAuthenticated();
      allow write: if isAdminOrToken();
    }

    // Resultados de exámenes por estudiante.
    match /results/{userId}/{phaseName}/{docId} {
      allow read: if isAdminOrToken() || (request.auth.uid == userId && canAccess());
      allow create, update: if request.auth.uid == userId && canAccess();
      allow delete: if request.auth.uid == userId && canAccess();
    }

    // Plan de estudio IA por estudiante.
    match /AnswerIA/{studentId}/{phaseName}/{subject} {
      allow read: if isAdminOrToken() || request.auth.uid == studentId;
      allow write: if false;
    }

    // Resumen académico IA — solo Cloud Functions escribe.
    match /ResumenStudent/{studentId}/{phase}/resumenActual {
      allow read: if isAdminOrToken() ||
        request.auth.uid == studentId ||
        (
          exists(/databases/$(database)/documents/superate/auth/userLookup/$(studentId)) &&
          tokenSameInstitution(
            get(/databases/$(database)/documents/superate/auth/userLookup/$(studentId)).data.institutionId
          )
        );
      allow write: if false;
    }

    // WebLinks: documentos consolidados por materia (consolidado_{materiaCode}).
    match /WebLinks/{docId} {
      allow read: if canAccess();
      allow create, update, delete: if isAdminOrToken();
    }

    // WebLinks: subcolección legacy (estructura antigua, solo admin).
    match /WebLinks/{grado}/{materia}/{topic}/links/{linkId} {
      allow read: if isAdminOrToken();
      allow create, update, delete: if isAdminOrToken();
    }

    // YoutubeLinks: documentos consolidados por materia.
    match /YoutubeLinks/{docId} {
      allow read: if canAccess();
      allow create, update, delete: if isAdminOrToken();
    }

    // YoutubeLinks: subcolección legacy (estructura antigua, solo admin).
    match /YoutubeLinks/{grado}/{materia}/{topic}/videos/{videoId} {
      allow read: if isAdminOrToken();
      allow create, update, delete: if isAdminOrToken();
    }

    // Herramientas IA.
    match /AI_Tools/{toolId} {
      allow read: if canAccess();
      allow create, update, delete: if isAdminOrToken();
    }

    // Tips ICFES.
    match /TipsIA/{docId} {
      allow read: if canAccess();
      allow create, update, delete: if isAdminOrToken();
    }

    // Simulacros tipo ICFES.
    match /Simulacros/{simulacroId} {
      allow read: if simulacroId.matches('^consolidado_[0-9]+$') || canAccess();
      allow create, update, delete: if isAdminOrToken();
      match /Videos/{videoId} {
        allow read: if canAccess();
        allow create, update, delete: if isAdminOrToken();
      }
      match /ICFES/{icfesDocId}/Videos/{videoId} {
        allow read: if canAccess();
        allow create, update, delete: if isAdminOrToken();
      }
    }

    // examRegistry legacy — solo lectura admin, sin escritura.
    match /examRegistry/{docId} {
      allow read: if isAdminOrToken();
      allow create, update, delete: if false;
    }

    // Vocabulario — solo Cloud Functions vía Admin SDK.
    match /definitionswords/{docId} {
      allow read, write: if false;
    }
    match /definitionswords/{materia}/palabras/{wordId} {
      allow read, write: if false;
    }

    // Denegar todo lo demás.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
