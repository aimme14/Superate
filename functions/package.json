{
  "name": "superate-functions",
  "version": "2.0.0",
  "description": "Cloud Functions para el sistema de justificaciones con IA de Supérate",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "generate-justifications": "npm run build && node lib/scripts/generateJustifications.js",
    "view-justifications": "npm run build && node lib/scripts/viewJustifications.js",
    "test": "npm run build && node lib/scripts/test-study-plan-smoke.js",
    "test:smoke": "npm run build && node lib/scripts/test-study-plan-smoke.js",
    "verify:plan": "npm run build && node lib/scripts/verifyPlanOptimizations.js",
    "verify:generate": "npm run build && node lib/scripts/generateAndVerifyPlan.js",
    "verify:ejercicios-ia-reads": "npm run build && node lib/scripts/verifyEjerciciosIAReads.js",
    "backfill:ejercicios-ia-rand": "npm run build && node lib/scripts/backfillEjerciciosIARand.js",
    "migrate-videos": "npm run build && node lib/scripts/migrateVideosToAnswerIA.js",
    "migrate-weblinks": "npm run build && node lib/scripts/migrateWebLinks.js",
    "migrate-youtube-grade": "npm run build && node lib/scripts/migrateYoutubeLinksToGrade.js",
    "generate-tips": "npm run build && node lib/scripts/generateTipsICFES.js",
    "rebuild-student-summary": "npm run build && node lib/scripts/rebuildStudentProgressSummary.js",
    "temp-backfill-sede": "npm run build && node lib/scripts/tempBackfillSedeAcademicYear.js",
    "align-student-from-summary": "npm run build && node lib/scripts/alignStudentFromSummary.js",
    "sync-auth-claims": "npm run build && node lib/scripts/syncAllAuthClaims.js",
    "reconcile-auth-users": "npm run build && node lib/scripts/reconcileAuthUsers.js",
    "rebuild-tips-ia-consolidado": "npm run build && node lib/scripts/rebuildTipsIAConsolidado.js",
    "rebuild-ai-tools-consolidado": "npm run build && node lib/scripts/rebuildAIToolsConsolidado.js",
    "rebuild-weblinks-consolidado": "npm run build && node lib/scripts/rebuildWebLinksConsolidado.js",
    "rebuild-youtubelinks-consolidado": "npm run build && node lib/scripts/rebuildYoutubeLinksConsolidado.js",
    "lint": "eslint --ext .ts src/",
    "lint:fix": "eslint --ext .ts src/ --fix"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.0",
    "@types/pdfkit": "^0.17.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^7.2.2",
    "google-auth-library": "^10.5.0",
    "jsonrepair": "^3.13.1",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.29.0",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.3.3"
  },
  "private": true,
  "author": "Supérate Team",
  "license": "UNLICENSED"
}
